# Airflow webserver base URL (no trailing slash required)
AIRFLOW_BASE_URL=http://localhost:8080

# --- Version targeting ---
# Which Airflow version are you talking to? Set explicitly or leave as
# 'auto' to probe /api/v2/version (falling back to /api/v1/version) at
# startup. Valid values: 2.2.x, 2.3.x, 2.4.0+, 2.5.0+, ... 3.0.0+, auto
AIRFLOW_TARGET_VERSION=auto
# Force a specific API path regardless of target (auto | v1 | v2).
# Leave as 'auto' to use the version-appropriate one.
AIRFLOW_API_VERSION=auto

# --- Auth: pick one mode ---
# Option 1: bearer token (wins over basic auth)
# AIRFLOW_TOKEN=xxxxxxxxxxxxxxxx

# Option 2: basic auth (required if AIRFLOW_TOKEN is unset)
AIRFLOW_USERNAME=airflow
AIRFLOW_PASSWORD=airflow

# --- Safety ---
# Read-only by default: mutating tools (trigger/set/delete/pause/clear) are
# hidden. Set false to expose them, or use AIRFLOW_ENABLED_TOOLS for a custom
# allowlist (overrides AIRFLOW_READ_ONLY).
AIRFLOW_READ_ONLY=true
# AIRFLOW_ENABLED_TOOLS=list_dags,get_dag,list_dag_runs,get_task_logs,get_health

# --- Token economy ---
AIRFLOW_LIST_PAGE_DEFAULT=20
AIRFLOW_LIST_PAGE_MAX=100
AIRFLOW_LOG_MAX_BYTES=4096
AIRFLOW_LOG_MAX_LINES=200

# --- Optional ---
AIRFLOW_TIMEOUT=30
AIRFLOW_VERIFY_SSL=true
AIRFLOW_MAX_RETRIES=3
AIRFLOW_MCP_LOG_LEVEL=INFO
# AIRFLOW_MCP_TRANSPORT=stdio

